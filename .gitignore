# =============================================================================
# Airymax Desktop .gitignore
# 版本: 2.1.0
# 最后更新: 2026-06-19
# 用途: 排除构建产物、依赖目录、环境配置文件及本地开发临时文件
# 模块定位: Airymax 桌面端，面向普通个人用户 (Tauri + Vite + TypeScript)
# 所有权: SPHARX Ltd
# Part of Airymax open-source project
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnpm-store/

# -----------------------------------------------------------------------------
# Build output
# -----------------------------------------------------------------------------
dist/
dist-ssr/
build/

# -----------------------------------------------------------------------------
# Rust / Tauri
# -----------------------------------------------------------------------------
src-tauri/target/
src-tauri/gen/
src-tauri/WixTools/
src-tauri/icons/
Cargo.lock

# -----------------------------------------------------------------------------
# Vite
# -----------------------------------------------------------------------------
.vite/
*.local

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo

# -----------------------------------------------------------------------------
# IDE and Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
.trae/
*.swp
*.swo
*~
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Environment (sensitive)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.staging

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# -----------------------------------------------------------------------------
# Python (if any scripting)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
.cache/
.temp/
*.tmp
*.bak
*.backup

# Internal Documentation (not needed in git)
src/design-system/
